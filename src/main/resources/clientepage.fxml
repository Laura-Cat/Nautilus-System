<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.ClienteViewController">
    <left>
        <VBox spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <children>
                <Label fx:id="labelNomeCliente" style="-fx-text-fill: white; -fx-font-size: 18;" text="Benvenuto!" />
                <Separator />
                <Button fx:id="btnPrenota" maxWidth="Infinity" text="Prenota Lezione" />
                <Button fx:id="btnAbbonamenti" maxWidth="Infinity" text="Miei Abbonamenti" />
                <Button fx:id="btnLogout" maxWidth="Infinity" onAction="#logout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea">
            <children>
                <Label text="Seleziona un'operazione dal menu a sinistra" />
            </children>
        </StackPane>
    </center>
</BorderPane>