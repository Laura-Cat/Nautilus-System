<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<StackPane fx:id="rootPane" prefHeight="750.0" prefWidth="1300.0" styleClass="sfondo-pulito" stylesheets="@../style/styleLogin.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.javafx.LoginView">
    <children>

        <AnchorPane mouseTransparent="true" style="-fx-background-color: transparent;">
            <children>
                <ImageView fitHeight="400.0" fitWidth="400.0" opacity="0.15" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="-20.0" AnchorPane.leftAnchor="-20.0">
                    <image>
                        <Image url="@../images/decorazione1.png" />
                    </image>
                </ImageView>
                <ImageView fitHeight="300.0" fitWidth="300.0" opacity="0.15" pickOnBounds="true" preserveRatio="true" AnchorPane.rightAnchor="-20.0" AnchorPane.topAnchor="-20.0">
                    <image>
                        <Image url="@../images/decorazione2.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>

        <VBox alignment="CENTER" fillWidth="false" style="-fx-background-color: transparent;">
            <children>
                <HBox alignment="CENTER" spacing="80.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>

                        <VBox alignment="CENTER" styleClass="slideshow-widget-box">
                            <children>
                                <ImageView fx:id="immagineSlideshow" fitHeight="420.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="false" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="500.0" prefWidth="350.0" spacing="15.0" styleClass="pannello-login">
                            <children>
                                <ImageView fitHeight="170.0" fitWidth="230.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/logo.png" />
                                    </image>
                                </ImageView>

                                <VBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="emailField" promptText="Email" styleClass="campo-testo" />
                                        <PasswordField fx:id="passwordField" promptText="Password" styleClass="campo-testo" />
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" spacing="8.0" maxWidth="Infinity">
                                    <children>
                                        <Button fx:id="loginButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#bottoneAccediCliccato" styleClass="bottone-primario" text="ACCEDI" />
                                        <Hyperlink text="Password dimenticata?" onAction="#passwordDimenticataCliccata" styleClass="link-password"/>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <javafx.scene.control.Separator HBox.hgrow="ALWAYS" />
                                        <Label text="oppure" textFill="#94a3b8" style="-fx-font-size: 12px;" />
                                        <javafx.scene.control.Separator HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <VBox spacing="10.0" maxWidth="Infinity">
                                    <children>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#loginConGoogle" styleClass="bottone-google" text="G  Accedi con Google" />
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#loginConFacebook" styleClass="bottone-facebook" text="f   Accedi con Facebook" />
                                    </children>
                                </VBox>

                            </children>
                            <padding>
                                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox alignment="BOTTOM_CENTER" mouseTransparent="true" pickOnBounds="false" style="-fx-background-color: transparent;" StackPane.alignment="BOTTOM_CENTER">
            <padding>
                <Insets bottom="20.0" />
            </padding>
            <children>
                <Label styleClass="testo-footer" text="© 2026 Nautilus Systems - Versione 2.0" />
            </children>
        </VBox>

    </children>
</StackPane>