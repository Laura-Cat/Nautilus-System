<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.PagamentoPopupView">
    <children>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Scegli il metodo di pagamento" />
        <Label fx:id="labelImporto" style="-fx-font-size: 16px; -fx-text-fill: #10b981;" text="Importo da pagare: € 0.00" />

        <Button mnemonicParsing="false" onAction="#pagaConPayPal" style="-fx-background-color: #f8fafc; -fx-text-fill: #003087; -fx-font-weight: bold; -fx-pref-width: 250; -fx-padding: 10; -fx-border-color: #003087; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="  Paga con PayPal">
            <graphic>
                <ImageView fitHeight="25.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/paypal.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>

        <Button mnemonicParsing="false" onAction="#pagaConCarta" style="-fx-background-color: #f8fafc; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-pref-width: 250; -fx-padding: 10; -fx-border-color: #fed800; -fx-border-width: 2; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="  Paga con PostePay">
            <graphic>
                <ImageView fitHeight="25.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/postepay.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
    </children>
</VBox>
