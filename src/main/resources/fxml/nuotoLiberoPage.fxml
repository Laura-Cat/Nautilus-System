<?xml version="1.0" encoding="UTF-8"?>
<?language java?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@/style/styleNuotoLibero.css" styleClass="sfondo-pagina" alignment="TOP_CENTER" spacing="25.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.NuotoLiberoView">

    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <children>
        <Label text="Prenotazione Nuoto Libero 🏊‍♂️" styleClass="titolo-pagina" />

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Label text="Seleziona la data:" styleClass="testo-normale"/>
                <DatePicker fx:id="calendarioNuoto" onAction="#giornoSelezionato" promptText="Scegli un giorno" prefWidth="200.0"/>
            </children>
        </HBox>

        <Separator />

        <VBox fx:id="boxListaCorsie" styleClass="box-corsie" VBox.vgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0">
            <children>
                <Label text="Seleziona una data dal calendario per visualizzare le corsie disponibili." style="-fx-text-fill: #7f8c8d; -fx-font-style: italic; -fx-font-size: 14px;" />
            </children>
        </VBox>
    </children>

</VBox>
