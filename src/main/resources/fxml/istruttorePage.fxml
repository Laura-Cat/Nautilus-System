<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="mainPane" stylesheets="@../style/styleCliente.css" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.JavaFX.IstruttoreView">

    <left>
        <VBox spacing="10" styleClass="sidebar">
            <children>
                <Label fx:id="labelNomeIstruttore" styleClass="testo-benvenuto" text="Benvenuto, Istruttore!" />
                <Separator />

                <Button text="📅 Agenda Settimanale" onAction="#apriCalendario" styleClass="bottone-menu-laterale" />

                <StackPane alignment="TOP_RIGHT">
                    <children>
                        <Button fx:id="btnNotifiche" maxWidth="Infinity" text="🔔 Notifiche" onAction="#apriGestioneRichieste" />
                        <Circle fx:id="pallinoRosso" fill="#ef4444" radius="5.0" visible="false">
                            <StackPane.margin>
                                <Insets right="10.0" top="5.0" />
                            </StackPane.margin>
                        </Circle>
                    </children>
                </StackPane>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnLogout" maxWidth="Infinity" onAction="#logout" text="Logout" style="-fx-text-fill: #ef4444;" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <children>
                <Label text="Seleziona un'operazione dal menu a sinistra" style="-fx-text-fill: #64748b; -fx-font-size: 16px;" />
            </children>
        </StackPane>
    </center>
</BorderPane>